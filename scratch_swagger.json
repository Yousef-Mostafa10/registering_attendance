  "components": {
    "schemas": {
      "ActivateAccountDto": {
        "required": [
          "deviceId",
          "newPassword",
          "universityCode",
          "universityEmail"
        ],
        "type": "object",
        "properties": {
          "universityEmail": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "universityCode": {
            "minLength": 1,
            "type": "string"
          },
          "newPassword": {
            "minLength": 6,
            "type": "string"
          },
          "deviceId": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "AdminCreateCourseDto": {
        "required": [
          "courseCode",
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "description": {
            "maxLength": 500,
            "type": "string",
            "nullable": true
          },
          "courseCode": {
            "minLength": 1,
            "type": "string"
          },
          "doctorId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "BulkEnrollmentDto": {
        "type": "object",
        "properties": {
          "courseId": {
            "type": "integer",
            "format": "int32"
          },
          "studentCodes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateDoctorDto": {
        "required": [
          "email",
          "name",
          "password"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
